                              dataType="System.String"
                              description="Derived Column Expression"
                              name="Expression">(#{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]} - 1) / 3 + 1</property>
                            <property
