                          truncationRowDisposition="FailComponent">
                          <properties>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Expression"
                              name="Expression">(DT_I4)((DT_WSTR,4)#{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Year]} + [RIGHT]("0" + (DT_WSTR,2)#{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]},2))</property>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Friendly Expression"
                              expressionType="Notify"
                              name="FriendlyExpression">(DT_I4)((DT_WSTR,4)Year + RIGHT("0" + (DT_WSTR,2)Month,2))</property>
