                          truncationRowDisposition="FailComponent">
                          <properties>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Expression"
                              name="Expression">#{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]} == 1 ? "January" : #{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]} == 2 ? "February" : #{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]} == 3 ? "March" : #{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]} == 4 ? "April" : #{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]} == 5 ? "May" : #{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]} == 6 ? "June" : #{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]} == 7 ? "July" : #{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]} == 8 ? "August" : #{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]} == 9 ? "September" : #{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]} == 10 ? "October" : #{Package\Sequence Container\Date\OLE DB Source.Outputs[OLE DB Source Output].Columns[Month]} == 11 ? "November" : "December"</property>
                            <property
                              containsID="true"
                              dataType="System.String"
                              description="Derived Column Friendly Expression"
                              expressionType="Notify"
                              name="FriendlyExpression">Month == 1 ? "January" : Month == 2 ? "February" : Month == 3 ? "March" : Month == 4 ? "April" : Month == 5 ? "May" : Month == 6 ? "June" : Month == 7 ? "July" : Month == 8 ? "August" : Month == 9 ? "September" : Month == 10 ? "October" : Month == 11 ? "November" : "December"</property>
